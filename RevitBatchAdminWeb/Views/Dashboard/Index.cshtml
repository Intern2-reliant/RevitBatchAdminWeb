@model RevitBatchAdminWeb.Controllers.DashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
}

<h2>Revit Batch SaaS Admin Dashboard</h2>

<div style="display:grid;grid-template-columns:repeat(2, 300px);gap:20px;margin-top:30px;">

    <div style="padding:20px;border:1px solid #ccc;border-radius:8px;">
        <h4>Total Users</h4>
        <h2>@Model.TotalUsers</h2>
    </div>

    <div style="padding:20px;border:1px solid #ccc;border-radius:8px;">
        <h4>Total Licenses</h4>
        <h2>@Model.TotalLicenses</h2>
    </div>

    <div style="padding:20px;border:1px solid #ccc;border-radius:8px;">
        <h4>Active Licenses</h4>
        <h2>@Model.ActiveLicenses</h2>
    </div>

    <div style="padding:20px;border:1px solid #ccc;border-radius:8px;">
        <h4>Inactive Licenses</h4>
        <h2>@Model.InactiveLicenses</h2>
    </div>

    <div style="padding:20px;border:1px solid #ccc;border-radius:8px;">
        <h4>License Managers</h4>
        <h2>@Model.ContractManagers</h2>
    </div>

</div>
@model RevitBatchAdminWeb.Models.CreateLicenseViewModel

@{
    ViewData["Title"] = "Create License";
}

<h2>Create License</h2>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label class="form-label">User / Contract Manager</label>
        <select asp-for="UserId" class="form-control">
            <option value="">-- Select User --</option>
            @foreach (var user in Model.Users.Where(u => u.role != "admin"))
            {
                <option value="@user.id">
                    @user.username (@user.role)
                </option>
            }
        </select>
        <span asp-validation-for="UserId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Expiry Date</label>
        <input asp-for="ExpiryDate" type="date" class="form-control" />
        <span asp-validation-for="ExpiryDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Quantity</label>
        <input asp-for="Quantity" type="number" class="form-control" min="1" />
        <small class="form-text text-muted">
            Use 1 when upgrading a normal user to Contract Manager. Use multiple for creating sub-licenses under a Contract Manager.
        </small>
        <span asp-validation-for="Quantity" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Create License</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
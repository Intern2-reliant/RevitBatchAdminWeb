@model RevitBatchAdminWeb.Services.CreateUserDto

@{
    ViewData["Title"] = "Create User";
}

<h2>Create User</h2>

<form asp-action="Create" method="post" style="max-width:500px;">

    <div class="mb-3">
        <label>Username</label>
        <input asp-for="Username" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Role</label>
        <select asp-for="Role" class="form-control">
            <option value="user">user</option>
            <option value="admin">admin</option>
            <option value="contract manager">contract manager</option>
        </select>
    </div>

    <div class="mb-3">
        <label>License Count</label>
        <input asp-for="LicenseCount" type="number" min="1" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Expiry Date</label>
        <input asp-for="ExpiryDate" type="date" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Create</button>
    <a href="/Users" class="btn btn-secondary">Cancel</a>

</form>